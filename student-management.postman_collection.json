              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/students?page=1&limit=10&name=&className=&section=",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "students"],
              "query": [
                {"key": "page", "value": "1"},
                {"key": "limit", "value": "10"},
                {"key": "name", "value": ""},