{
  "info": {
    "name": "Student Management API",
    "description": "Complete CRUD operations for student management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Students",
      "item": [
        {
          "name": "Get All Students",
          "request": {
